# Example environment file for check-nextcloud-security.
#
# Copy this to /etc/check-nextcloud-security/env and adjust the values,
# then reference it from the systemd unit (see check-nextcloud-security.service)
# or a cron job (see ../cron/check-nextcloud-security.cron).
#
# All options accepted on the command line can also be set here using their
# CNS_ prefixed environment variable name. An explicit CLI flag always wins
# over the environment variable.

# Required: the Nextcloud hostname to scan (not an IP address).
CNS_HOST=nextcloud.example.com

# Optional: HTTP/HTTPS proxy to reach scan.nextcloud.com through.
#CNS_PROXY=http://proxy.example.com:3128

# Optional: trigger a fresh rescan on every run instead of reusing the last
# cached result. Avoid combining this with frequent schedules - see the
# "Rescan" section in README.md.
#CNS_RESCAN=false

# Optional: verbose debug logging.
#CNS_DEBUG=false

# Optional: retry/backoff tuning for transient network errors.
#CNS_RETRIES=2
#CNS_BACKOFF_FACTOR=0.5
